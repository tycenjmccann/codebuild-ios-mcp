{
  "name": "codebuild-ios-mcp",
  "version": "1.0.0",
  "description": "AWS CodeBuild macOS iOS build+test runner exposed to AI agents as MCP tools via an Amazon Bedrock AgentCore Gateway. CDK v2 (TypeScript).",
  "license": "MIT",
  "bin": {
    "codebuild-ios-mcp": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "synth": "cdk synth",
    "deploy": "cdk deploy",
    "destroy": "cdk destroy"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "aws-cdk": "^2.160.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.160.0",
    "constructs": "^10.3.0",
    "js-yaml": "^4.1.0",
    "@types/js-yaml": "^4.0.9"
  }
}
