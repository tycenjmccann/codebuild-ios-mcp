{
  "app": "npx ts-node --prefer-ts-exts bin/app.ts",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/*.d.ts",
      "**/*.js",
      "tsconfig.json",
      "package*.json",
      "node_modules",
      "lib/**/*.js",
      "bin/**/*.js"
    ]
  },
  "context": {
    "@aws-cdk/aws-iam:minimizePolicies": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/core:target-partitions": ["aws", "aws-cn"],
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:bootstrapQualifier": "hnb659fds",

    "codebuild-ios-mcp:githubRepo": "https://github.com/aws-samples/aws-mobile-ios-notes-tutorial",
    "codebuild-ios-mcp:sourceVersion": "main",
    "codebuild-ios-mcp:projectDir": ".",
    "codebuild-ios-mcp:defaultDevice": "iPhone 17",
    "codebuild-ios-mcp:artifactRetentionDays": 14,
    "codebuild-ios-mcp:presignTtlSec": 3600,

    "//vpc": "OPTIONAL — set these to run builds inside your VPC (reach private Nexus, internal validation services). Leave empty for no VPC. subnetIds/securityGroupIds are comma-separated.",
    "codebuild-ios-mcp:vpcId": "",
    "codebuild-ios-mcp:subnetIds": "",
    "codebuild-ios-mcp:securityGroupIds": ""
  }
}
